# Clara Automation Pipeline - Environment Variables
# Copy this file to .env and fill in your values

# ---- LLM Configuration ----
# Ollama (local, preferred - zero cost)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq API (free tier fallback - get key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ---- Output Configuration ----
# Where to store outputs (defaults to ./outputs relative to project root)
OUTPUTS_DIR=./outputs

# ---- n8n Configuration ----
# Used when running via n8n Docker
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=false

# ---- Optional: Retell API ----
# Only needed for live agent creation (not required for spec generation)
RETELL_API_KEY=your_retell_api_key_if_available
